{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Metrics",
  "description": "Schema for metrics YAML files — agent performance and cost tracking",
  "type": "object",
  "required": ["project", "updated"],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1,
      "description": "Project name"
    },
    "updated": {
      "type": "string",
      "format": "date",
      "description": "Date metrics were last updated"
    },
    "sprints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^S\\d{3,}$",
            "description": "Sprint identifier"
          },
          "tasks_planned": {
            "type": "integer",
            "minimum": 0
          },
          "tasks_completed": {
            "type": "integer",
            "minimum": 0
          },
          "tasks_blocked": {
            "type": "integer",
            "minimum": 0
          },
          "total_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "total_duration_minutes": {
            "type": "integer",
            "minimum": 0
          },
          "velocity": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "agent_performance": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_-]*$": {
          "type": "object",
          "properties": {
            "tasks_completed": {
              "type": "integer",
              "minimum": 0
            },
            "avg_tokens_per_task": {
              "type": "integer",
              "minimum": 0
            },
            "avg_duration_minutes": {
              "type": "integer",
              "minimum": 0
            },
            "retry_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "object",
      "properties": {
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "cost_per_task_avg": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "quality": {
      "type": "object",
      "properties": {
        "tasks_with_test_failures": {
          "type": "integer",
          "minimum": 0
        },
        "tasks_requiring_rework": {
          "type": "integer",
          "minimum": 0
        },
        "human_interventions": {
          "type": "integer",
          "minimum": 0
        },
        "stuck_incidents": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
